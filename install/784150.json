{
  "game_id": "784150",
  "game_name": "Workers & Resources: Soviet Republic",
  "description": "Установка Workshop-мода в workshop_wip",
  "version": "1",

  "questions": [
    {
      "id": "GAME_PATH",
      "type": "text",
      "label": "Укажите путь к папке игры",
      "default": "C:/games/SovietRepublic",
      "hint": "Папка с Workers & Resources: Soviet Republic"
    }
  ],

  "steps": [
    {
      "action": "set_var",
      "name": "game_folder",
      "value": "{GAME_PATH}"
    },

    {
      "action": "set_var",
      "name": "mod_id",
      "value": "{workshop_id}"
    },

    {
      "action": "copy",
      "label": "Устанавливаем мод",
      "when": "dir_exists('{game_folder}/media_soviet/workshop_wip') && !dir_exists('{game_folder}/media_soviet/workshop_wip/{mod_id}')",
      "src": "{mod_folder}",
      "dst": "{game_folder}/media_soviet/workshop_wip/{mod_id}",
      "files": [
        {
          "from": "**",
          "to": ".",
          "overwrite": false
        }
      ]
    }
  ],

  "uninstall": [
    {
      "action": "set_var",
      "name": "game_folder",
      "value": "{GAME_PATH}"
    },

    {
      "action": "set_var",
      "name": "mod_id",
      "value": "{workshop_id}"
    },

    {
      "action": "delete",
      "label": "Удаляем мод",
      "base": "{game_folder}/media_soviet/workshop_wip",
      "rules": [
        {
          "glob": "{mod_id}/",
          "recursive": true,
          "missing_ok": true
        }
      ]
    }
  ]
}
