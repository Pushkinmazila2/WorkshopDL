{
  "game_id": "784150",
  "game_name": "Workers & Resources: Soviet Republic",
  "user_inputs": [
    {
      "id": "INSTALL_MODE",
      "label": "Выберите тип установки (версию игры)",
      "type": "select",
      "items": ["Автодетекция", "Steam-версия (Воркшоп)", "GOG / Другая версия (Вручную)"],
      "default": "Автодетекция"
    },
    {
      "id": "BACKUP_ENABLED",
      "label": "Создавать резервную копию изменяемых конфигов?",
      "type": "checkbox",
      "default": true
    },
    {
      "id": "CUSTOM_MOD_PREFIX",
      "label": "Префикс для папки мода (оставьте пустым, если не нужен)",
      "type": "text",
      "default": ""
    }
  ],
  "stages": [
    {
      "name": "Поиск путей игры",
      "when": "{INSTALL_MODE} == 'Автодетекция'",
      "action": "_pf_find_game_folder",
      "args": {
        "paths_to_check": [
          "{STEAM}/steamapps/common/SovietRepublic",
          "C:/GOG Games/Workers Resources Soviet Republic",
          "D:/GOG Games/Workers Resources Soviet Republic"
        ],
        "registry_keys": [
          "SOFTWARE\\WOW6432Node\\GOG.com\\Games\\1314983050\\path"
        ],
        "env_vars": ["SOVIET_REPUBLIC_HOME"]
      },
      "save_to_context": "DETECTED_GAME_FOLDER"
    },
    {
      "name": "Установка для Steam-версии",
      "when": "{PLATFORM} == 'steam' or {INSTALL_MODE} == 'Steam-версия (Воркшоп)'",
      "actions": [
        {
          "comment": "Steam ищет моды в папке workshop/content/784150/{ID_мода}",
          "action": "_pf_smart_copy",
          "args": {
            "from": "{DOWNLOAD_CACHE}/*",
            "to": "{STEAM}/steamapps/workshop/content/784150/{CUSTOM_MOD_PREFIX}{DOWNLOADED_MOD_ID}/",
            "flatten": false,
            "overwrite": true
          }
        }
      ]
    },
    {
      "name": "Установка для GOG / Non-Steam версии",
      "when": "{PLATFORM} == 'gog' or {INSTALL_MODE} == 'GOG / Другая версия (Вручную)'",
      "actions": [
        {
          "comment": "В GOG-версии моды должны лежать строго в media_soviet/workshop_wip/{ID_мода}",
          "action": "_pf_smart_copy",
          "args": {
            "from": "{DOWNLOAD_CACHE}/*",
            "to": "{DETECTED_GAME_FOLDER}/media_soviet/workshop_wip/{CUSTOM_MOD_PREFIX}{DOWNLOADED_MOD_ID}/",
            "flatten": false,
            "overwrite": true
          }
        },
        {
          "comment": "Пример использования патча конфигов: если моду требуется прописка в ini игры",
          "when": "{BACKUP_ENABLED} == true",
          "action": "_pf_patch_ini",
          "args": {
            "file_path": "{DETECTED_GAME_FOLDER}/media_soviet/config.ini",
            "section": "InstalledMods",
            "key": "Mod_{DOWNLOADED_MOD_ID}",
            "value": "1"
          }
        }
      ]
    }
  ]
}
